alias tok="~/.local/bin/zbw.zsh fields output"
# Space-based alias expansion (simpler version)
expand-alias-and-accept() {
  # Get the first word of the command line
  local cmd=${${(Az)LBUFFER}[1]}
  # Check if it's an alias
  if [[ -n $cmd ]] && alias $cmd &>/dev/null; then
    # Get the alias definition
    local expanded_cmd=$(alias $cmd | sed "s/^$cmd=//;s/^'//;s/'$//")
    # Replace the alias with its definition
    LBUFFER="${LBUFFER/$cmd/$expanded_cmd}"
  fi
  # Insert a space
  LBUFFER+=" "
}

# Create the widget and bind it to space
zle -N expand-alias-and-accept
bindkey " " expand-alias-and-accept
autoload -Uz edit-command-line
zle -N edit-command-line

# If using built-in vi mode
