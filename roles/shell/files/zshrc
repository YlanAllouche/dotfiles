# Add this to your ~/.zshrc

# Widget for password completion (Ctrl+A)
rbw-password-completion() {
    local result
    result=$(~/.local/bin/zbw.zsh password completion 2>/dev/null)
    if [[ $? -eq 0 && -n "$result" ]]; then
        LBUFFER="${LBUFFER}${result}"
    fi
    zle redisplay
}

# Widget for fields completion (Ctrl+Shift+A) 
rbw-fields-completion() {
    local result
    result=$(~/.local/bin/zbw.zsh fields completion 2>/dev/null)
    if [[ $? -eq 0 && -n "$result" ]]; then
        LBUFFER="${LBUFFER}${result}"
    fi
    zle redisplay
}

# Register the widgets
zle -N rbw-password-completion
zle -N rbw-fields-completion

# Bind to key combinations
