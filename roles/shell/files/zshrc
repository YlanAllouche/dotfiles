# Increase function nesting limit

FUNCNEST=1000
export CLICOLOR=1

# Source antidote
if [[ -f /usr/share/zsh-antidote/antidote.zsh ]]; then
    source /usr/share/zsh-antidote/antidote.zsh
else
    for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [[ -x "$brew_bin" ]]; then
            antidote_prefix="$($brew_bin --prefix antidote 2>/dev/null)"
            if [[ -n "$antidote_prefix" && -f "$antidote_prefix/share/antidote/antidote.zsh" ]]; then
                source "$antidote_prefix/share/antidote/antidote.zsh"
                break
            fi
            if [[ -f "$($brew_bin --prefix)/share/antidote/antidote.zsh" ]]; then
                source "$($brew_bin --prefix)/share/antidote/antidote.zsh"
                break
            fi
        fi
    done
fi


# Create plugins file if it doesn't exist
if [ ! -f ${ZDOTDIR:-~}/.zsh_plugins.txt ]; then
    touch ${ZDOTDIR:-~}/.zsh_plugins.txt
fi


# Basic zsh settings
setopt AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT
setopt EXTENDED_GLOB
setopt HIST_IGNORE_ALL_DUPS HIST_FIND_NO_DUPS HIST_REDUCE_BLANKS SHARE_HISTORY
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history

# Editor
export VISUAL=nvim
export EDITOR=nvim

# FZF settings
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --info=inline"
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# Autosuggestions settings - reduce complexity
ZSH_AUTOSUGGEST_STRATEGY=(history)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
ZSH_AUTOSUGGEST_USE_ASYNC=1
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# Vi mode settings
ZVM_INIT_MODE=sourcing
ZVM_VI_INSERT_ESCAPE_BINDKEY=jk

# Load plugins
antidote load

# Initialize completion system
autoload -Uz compinit && compinit

# Completion styling
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# Custom FZF functions
fh() {
    print -z $( ([ -n "$ZSH_NAME" ] && fc -l 1 || history) | fzf +s --tac | sed -E 's/ _[0-9]_\*? *//' | sed -E 's/\\/\\\\/g')
}

fd() {
    local dir
    dir=$(find ${1:-.} -path '*/\.*' -prune -o -type d -print 2> /dev/null | fzf +m) &&
    cd "$dir"
}

ff() {
    local files
    IFS=$'\n' files=($(fzf --query="$1" --multi --select-1 --exit-0))
    [[ -n "$files" ]] && ${EDITOR:-vim} "${files[@]}"
}


# Basic key bindings - these will be overridden by zsh-vi-mode if needed
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^R' fzf-history-widget
bindkey '^T' fzf-file-widget
bindkey '^[c' fzf-cd-widget
bindkey '^ ' autosuggest-accept

# Function to run after vi mode initializes
function zvm_after_init() {
    # Restore key bindings in vi insert mode
    bindkey -M viins '^R' fzf-history-widget
    bindkey -M viins '^P' fzf-file-widget
    bindkey -M viins '^[c' fzf-cd-widget
    bindkey -M viins '^ ' autosuggest-accept
    
    # Set up history navigation in command mode
    bindkey -M vicmd 'k' history-substring-search-up
    bindkey -M vicmd 'j' history-substring-search-down
}

