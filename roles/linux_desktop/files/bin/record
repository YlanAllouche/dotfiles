status_recording() {
    if recording_active; then
        local output_file=$(get_recording_info)
        local pid=$(get_recording_pid)
        echo "Recording in progress (PID: $pid): $output_file"
    else
        echo "No recording in progress"
    fi
}

case "$1" in
    "start")
        start_recording "$2"
        ;;
    "stop")
        stop_recording "$2"
        ;;
    "status")
        status_recording
        ;;
    *)
        echo "Usage: $0 <start|stop|status> [options]"
        echo ""
        echo "Actions:"
        echo "  start screen       - Record primary screen"
        echo "  start area         - Record selected area"
        echo "  stop               - Stop current recording"
        echo "  stop --gif         - Stop and convert to GIF (high quality)"
        echo "  status             - Check recording status"
        echo ""
        echo "GIF Conversion:"
        echo "  High Quality:      1280×696, 10fps, ~383KB"
        echo "  (Dithered version available in script comments, ~809KB)"
        exit 1
        ;;
esac
